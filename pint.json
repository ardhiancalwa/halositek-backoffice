{
    "preset": "laravel",
    "exclude": [
        "vendor",
        "storage",
        "bootstrap/cache",
        "public/build"
    ],
    "rules": {
        "concat_space": {
            "spacing": "one"
        },
        "single_line_empty_body": false,
        "new_with_parentheses": true,
        "php_unit_method_casing": false,
        "no_unused_imports": true,
        "ordered_imports": {
            "sort_algorithm": "alpha"
        }
    }
}
